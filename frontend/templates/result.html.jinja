{% extends "base.html.jinja" %}
{% block title %} — Results{% endblock %}

{% block content %}

{# ── Top bar ────────────────────────────────────────────────────────────── #}
<div class="d-flex align-items-center gap-3 mb-4">
  <a href="/" class="btn btn-outline-secondary btn-sm flex-shrink-0">← Back</a>
  <div>
    {% if data.title %}
      <h5 class="mb-0">{{ data.title }}</h5>
    {% endif %}
    <a href="{{ url }}" target="_blank" class="text-muted text-break">{{ url }}</a>
  </div>
</div>

{# ── Error ───────────────────────────────────────────────────────────────── #}
{% if error %}
<div class="alert alert-danger">
  <strong>Error:</strong> {{ error }}
</div>

{% else %}

{# ── Metrics card ─────────────────────────────────────────────────────────── #}
{% if data.metrics %}
<div class="card mb-4 shadow-sm">
  <div class="card-header fw-semibold">
    Evaluation Metrics <span class="text-muted fw-normal small">(vs Gold Standard)</span>
  </div>
  <div class="card-body">
    <div class="row g-4">
      {% for label, val in [
          ('Precision', data.metrics.precision),
          ('Recall',    data.metrics.recall),
          ('F1 Score',  data.metrics.f1)
      ] %}
      <div class="col-md-4">
        <div class="d-flex justify-content-between align-items-center mb-1">
          <span class="fw-medium">{{ label }}</span>
          <span class="badge fs-6
            {% if val >= 0.7 %}bg-success
            {% elif val >= 0.4 %}bg-warning text-dark
            {% else %}bg-danger{% endif %}">
            {{ "%.4f"|format(val) }}
          </span>
        </div>
        <div class="progress" style="height: 10px;">
          <div class="progress-bar
            {% if val >= 0.7 %}bg-success
            {% elif val >= 0.4 %}bg-warning
            {% else %}bg-danger{% endif %}"
            role="progressbar"
            style="width: {{ (val * 100)|round(1) }}%"
            aria-valuenow="{{ (val * 100)|round(1) }}"
            aria-valuemin="0" aria-valuemax="100">
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

{# ── Text comparison panels ───────────────────────────────────────────────── #}
{% set has_gs = data.gold_text is defined and data.gold_text %}

{# ── Row 1: Raw HTML | Parsed Markdown ───────────────────────────────────── #}
<div class="row g-3 mb-3">

  <div class="col-md-6">
    <div class="panel-header">
      <span class="fw-semibold">Raw HTML</span>
      <span class="text-muted small">{{ data.html_text.split()|length }} words</span>
    </div>
    <div class="text-panel"><pre class="mb-0">{{ data.html_text | e }}</pre></div>
  </div>

  <div class="col-md-6">
    <div class="panel-header">
      <span class="fw-semibold">Parsed Markdown</span>
      <span class="text-muted small">{{ data.parsed_text.split()|length }} words</span>
    </div>
    <div class="text-panel"><pre class="mb-0">{{ data.parsed_text | e }}</pre></div>
  </div>

</div>

{# ── Row 2: Cleaned Text | Gold Standard ─────────────────────────────────── #}
<div class="row g-3">

  <div class="col-md-6">
    <div class="panel-header">
      <span class="fw-semibold">Cleaned Text</span>
      <span class="text-muted small">{{ data.cleaned_text.split()|length }} words</span>
    </div>
    <div class="text-panel"><pre class="mb-0">{{ data.cleaned_text | e }}</pre></div>
  </div>

  {% if has_gs %}
  <div class="col-md-6">
    <div class="panel-header">
      <span class="fw-semibold">Gold Standard</span>
      <span class="text-muted small">{{ data.gold_text.split()|length }} words</span>
    </div>
    <div class="text-panel"><pre class="mb-0">{{ data.gold_text | e }}</pre></div>
  </div>
  {% endif %}

</div>

{# ── Monaco Diff Editor ───────────────────────────────────────────────────── #}
{% if has_gs %}
<div class="mt-4">
  <div class="panel-header mb-0" style="border-bottom: none; border-radius: 0.375rem 0.375rem 0 0;">
    <span class="fw-semibold">Diff: Cleaned Text vs Gold Standard</span>
    <span class="text-muted small">left = cleaned &nbsp;|&nbsp; right = gold</span>
  </div>
  <div id="monaco-diff-container" style="height: 600px; border: 1px solid #dee2e6; border-radius: 0 0 0.375rem 0.375rem;"></div>
</div>
{% endif %}

{% endif %}
{% endblock %}

{% block scripts %}
{% if not error and data.gold_text is defined and data.gold_text %}
<script>
  var __originalText = {{ data.cleaned_text | tojson }};
  var __modifiedText = {{ data.gold_text | tojson }};
</script>
<script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.52.0/min/vs/loader.js"></script>
<script>
  require.config({ paths: { vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.52.0/min/vs' } });
  require(['vs/editor/editor.main'], function () {
    monaco.editor.createDiffEditor(
      document.getElementById('monaco-diff-container'),
      {
        readOnly: true,
        renderSideBySide: true,
        automaticLayout: true,
        theme: 'vs',
        fontSize: 13,
        wordWrap: 'on',
        diffWordWrap: 'on',
        scrollBeyondLastLine: false,
        selectionHighlight: false,
        occurrencesHighlight: 'off',
        renderLineHighlight: 'none',
      }
    ).setModel({
      original: monaco.editor.createModel(__originalText, 'plaintext'),
      modified: monaco.editor.createModel(__modifiedText, 'plaintext'),
    });
  });
</script>
{% endif %}
{% endblock %}
